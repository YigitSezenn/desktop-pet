<Window x:Class="DesktopPet.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="DesktopPet"
        Width="170"
        Height="160"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        Topmost="True"
        ShowInTaskbar="False"
        ResizeMode="NoResize"
        ShowActivated="False"
        MouseLeftButtonDown="OnMouseDown"
        MouseMove="OnMouseMove"
        MouseLeftButtonUp="OnMouseUp"
        MouseRightButtonUp="OnRightClick"
        MouseDoubleClick="OnDoubleClick">
    <Grid x:Name="PetRoot" Cursor="Hand">
        <StackPanel VerticalAlignment="Bottom" HorizontalAlignment="Center">
            <Border x:Name="NameBubble"
                    Background="#F8FFFFFF"
                    BorderBrush="#33000000"
                    BorderThickness="1"
                    CornerRadius="8"
                    Padding="8,4"
                    Margin="0,0,0,4"
                    Visibility="Visible">
                <TextBlock x:Name="PetNameText"
                           FontFamily="Segoe UI"
                           FontSize="11"
                           FontWeight="SemiBold"
                           Foreground="#FF2D3436"
                           TextAlignment="Center"/>
            </Border>

            <Border x:Name="SpeechBubble"
                    Background="#F2FFFFFF"
                    BorderBrush="#22000000"
                    BorderThickness="1"
                    CornerRadius="8"
                    Padding="8,4"
                    Margin="0,0,0,6"
                    Visibility="Collapsed">
                <TextBlock x:Name="PetSpeechText"
                           FontFamily="Segoe UI"
                           FontSize="11"
                           Foreground="#FF2D3436"
                           TextAlignment="Center"
                           TextWrapping="Wrap"
                           MaxWidth="220"/>
            </Border>

            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Bottom">
                <Viewbox x:Name="PetVisual"
                         Width="112"
                         Height="96"
                         Stretch="Uniform"
                         UseLayoutRounding="True">
                    <Image x:Name="PetImage"
                           Width="32"
                           Height="32"
                           Stretch="None"
                           RenderOptions.BitmapScalingMode="NearestNeighbor"
                           RenderOptions.EdgeMode="Aliased"/>
                </Viewbox>
            </StackPanel>
        </StackPanel>
    </Grid>
</Window>
